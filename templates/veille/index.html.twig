{% extends 'base.html.twig' %}

{% block title %}Veille numérique - Portfolio Emeric Grall{% endblock %}

{% block body %}
    <div class="container py-5">
        <section class="mb-5">
            <span class="badge bg-primary mb-2">Veille numérique</span>
            <h1 class="display-5 fw-bold">Ma veille cybersécurité</h1>
            <p class="lead text-muted">Suivi des événements, menaces et outils de cybersécurité en lien avec ma formation BTS SIO SISR.</p>
        </section>

        <section class="mb-5">
            <h2 class="h3 fw-bold mb-4">Actualités par mois</h2>
            {% for month in veilleMonths %}
                <div class="mb-4">
                    <h3 class="h5 fw-semibold mb-3">{{ month.period }}</h3>
                    <div class="row g-3">
                        {% for article in month.articles %}
                            <div class="col-md-6">
                                <div class="card h-100 border-0 shadow-sm">
                                    <div class="card-body">
                                        <span class="badge bg-{{ article.color }} mb-2">{{ article.category }}</span>
                                        <h4 class="h6 card-title">{{ article.title }}</h4>
                                        <p class="text-muted small mb-2">
                                            <i class="fas {{ article.icon }} me-2"></i>{{ article.date }} • {{ article.source }}
                                        </p>
                                        <p class="card-text text-secondary">{{ article.summary }}</p>
                                    </div>
                                    <div class="card-footer bg-white border-top-0">
                                        <a href="{{ article.link }}" class="btn btn-sm btn-outline-primary" target="_blank" rel="noreferrer noopener">
                                            Lire l'article
                                        </a>
                                    </div>
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            {% endfor %}
        </section>

        <section class="mb-5">
            <h2 class="h3 fw-bold mb-4">Outils et sources de veille</h2>
            <div class="row g-4">
                {% for platform in veillePlatforms %}
                    <div class="col-md-4">
                        <div class="card h-100 border-0 shadow-sm">
                            <div class="card-body">
                                <div class="d-flex align-items-center mb-3">
                                    <span class="badge bg-{{ platform.color }} me-3">
                                        <i class="{{ platform.iconType }} {{ platform.icon }}"></i>
                                    </span>
                                    <h3 class="h6 mb-0">{{ platform.name }}</h3>
                                </div>
                                <p class="text-muted small">{{ platform.description }}</p>
                            </div>
                            <div class="card-footer bg-white border-top-0">
                                <a href="{{ platform.url }}" target="_blank" rel="noreferrer noopener" class="text-decoration-none">
                                    Visiter <i class="fas fa-arrow-right ms-1"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </section>
    </div>
{% endblock %}
