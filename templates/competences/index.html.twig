{% extends 'base.html.twig' %}

{% block title %}Compétences - Portfolio BTS SIO SISR{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="mb-5">
        <h1 class="display-4 fw-bold mb-3">Mes Compétences</h1>
        <p class="lead text-muted">
            Découvrez mes compétences techniques acquises durant ma formation BTS SIO SISR et mes expériences professionnelles.
        </p>
        
        <!-- Section pour le tableau de synthèse (style CV) -->
        <div class="card mb-5">
            <div class="card-body">
                <div class="row align-items-center">
                    <div class="col-md-8">
                        <h2 class="h4 fw-bold mb-3">Tableau de synthèse des compétences</h2>
                    </div>
                    <div class="col-md-4 text-md-end mt-3 mt-md-0">
                        <a href="{{ asset('fichier/syntheslam.pdf') }}" class="btn btn-primary" target="_blank">
                            <i class="fas fa-file-pdf me-2"></i>Voir le tableau de synthèse 
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
<!-- Section Infrastructure & Réseau (Priorité SISR) -->
    <div class="mb-5">
        <div class="d-flex align-items-center mb-4">
            <div class="me-3 text-primary">
                <i class="fas fa-server fa-2x"></i>
            </div>
            <h2 class="h3 fw-bold mb-0">Infrastructure, Systèmes et Réseaux</h2>
            <span class="badge bg-primary ms-3">Coeur de métier SISR</span>
        </div>
        
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="row">
                    {% for competence in competencesReseau %}
                        <div class="col-md-6 mb-4">
                            <div class="d-flex align-items-center mb-2">
                                <div class="me-3 text-{{ competence.couleur }}" style="width: 40px; text-align: center;">
                                    <i class="{{ competence.icone }} fa-2x"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <h3 class="h6 fw-bold mb-1">{{ competence.nom }}</h3>
                                    {# <div class="progress" style="height: 8px;">
                                        <div class="progress-bar bg-{{ competence.couleur }}" role="progressbar" style="width: {{ competence.niveau }}%;" aria-valuenow="{{ competence.niveau }}" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div> #}
                                </div>
                                {# <div class="ms-2 text-muted small">{{ competence.niveau }}%</div> #}
                            </div>
                            <p class="text-muted small ps-5">{{ competence.description }}</p>
                        </div>
                    {% endfor %}
                </div>
                
                <div class="mt-4">
                    <h3 class="h5 fw-bold mb-3">Projets infrastructure réalisés</h3>
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex align-items-center">
                            <i class="fas fa-check-circle text-success me-3"></i>
                            <div>
                                <strong>Active Directory</strong> - Configuration complète d'un domaine Windows Server avec GPO, DNS, DHCP
                            </div>
                        </li>
                        <li class="list-group-item d-flex align-items-center">
                            <i class="fas fa-check-circle text-success me-3"></i>
                            <div>
                                <strong>GLPI + FOG</strong> - Déploiement d'une solution de gestion de parc et déploiement d'images
                            </div>
                        </li>
                        <li class="list-group-item d-flex align-items-center">
                            <i class="fas fa-check-circle text-success me-3"></i>
                            <div>
                                <strong>Infrastructure Cisco</strong> - Configuration de VLANs, routage inter-VLAN et ACLs
                            </div>
                        </li>
                        <li class="list-group-item d-flex align-items-center">
                            <i class="fas fa-check-circle text-success me-3"></i>
                            <div>
                                <strong>Supervision réseau</strong> - Mise en place d'une solution de monitoring avec alertes
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <!-- Section Développement (acquis en SLAM) -->
    <div class="mb-5">
        <div class="d-flex align-items-center mb-4">
            <div class="me-3 text-secondary">
                <i class="fas fa-code fa-2x"></i>
            </div>
            <h2 class="h3 fw-bold mb-0">Développement & Scripting</h2>
            <span class="badge bg-secondary ms-3">Acquis en SLAM</span>
        </div>
        
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="row">
                    {% for competence in competencesDev %}
                        <div class="col-md-6 mb-4">
                            <div class="d-flex align-items-center mb-2">
                                <div class="me-3 text-{{ competence.couleur }}" style="width: 40px; text-align: center;">
                                    <i class="{{ competence.icone }} fa-2x"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <h3 class="h6 fw-bold mb-1">{{ competence.nom }}</h3>
                                    {# <div class="progress" style="height: 8px;">
                                        <div class="progress-bar bg-{{ competence.couleur }}" role="progressbar" style="width: {{ competence.niveau }}%;" aria-valuenow="{{ competence.niveau }}" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div> #}
                                </div>
                                {# <div class="ms-2 text-muted small">{{ competence.niveau }}%</div> #}
                            </div>
                            <p class="text-muted small ps-5">{{ competence.description }}</p>
                        </div>
                    {% endfor %}
                </div>
                
                <div class="mt-4">
                    <h3 class="h5 fw-bold mb-3">Projets de développement réalisés</h3>
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex align-items-center">
                            <i class="fas fa-check-circle text-success me-3"></i>
                            <div>
                                <strong>Application en Symfony</strong> - Développement de Stage Direct en Symfony
                            </div>
                        </li>
                        <li class="list-group-item d-flex align-items-center">
                            <i class="fas fa-check-circle text-success me-3"></i>
                            <div>
                                <strong>Application de gestion</strong> - Création d'une application de gestion des stocks et commandes
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
    
    
    
    <!-- Section Cybersécurité (Spécialisation SISR) -->
    <div class="mb-5">
        <div class="d-flex align-items-center mb-4">
            <div class="me-3 text-danger">
                <i class="fas fa-shield-alt fa-2x"></i>
            </div>
            <h2 class="h3 fw-bold mb-0">Cybersécurité</h2>
            <span class="badge bg-danger ms-3">Spécialisation</span>
        </div>
        
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="row">
                    {% for competence in competencesCyber %}
                        <div class="col-md-6 mb-4">
                            <div class="d-flex align-items-center mb-2">
                                <div class="me-3 text-{{ competence.couleur }}" style="width: 40px; text-align: center;">
                                    <i class="{{ competence.icone }} fa-2x"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <h3 class="h6 fw-bold mb-1">{{ competence.nom }}</h3>
                                    {# <div class="progress" style="height: 8px;">
                                        <div class="progress-bar bg-{{ competence.couleur }}" role="progressbar" style="width: {{ competence.niveau }}%;" aria-valuenow="{{ competence.niveau }}" aria-valuemin="0" aria-valuemax="100"></div>
                                    </div> #}
                                </div>
                                {# <div class="ms-2 text-muted small">{{ competence.niveau }}%</div> #}
                            </div>
                            <p class="text-muted small ps-5">{{ competence.description }}</p>
                        </div>
                    {% endfor %}
                </div>
                
                <div class="mt-4">
                    <h3 class="h5 fw-bold mb-3">Projets de cybersécurité réalisés</h3>
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item d-flex align-items-center">
                            <i class="fas fa-check-circle text-success me-3"></i>
                            <div>
                                <strong>Audit RGPD</strong> - Accompagnement d'une entreprise dans sa mise en conformité RGPD
                            </div>
                        </li>
                        <li class="list-group-item d-flex align-items-center">
                            <i class="fas fa-check-circle text-success me-3"></i>
                            <div>
                                <strong>Sécurisation infrastructure</strong> - Configuration de pare-feu et mise en place de VPN
                            </div>
                        </li>
                        <li class="list-group-item d-flex align-items-center">
                            <i class="fas fa-check-circle text-success me-3"></i>
                            <div>
                                <strong>Analyse de vulnérabilités</strong> - Utilisation d'outils d'audit réseau (Nmap, Wireshark)
                            </div>
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

{% endblock %}

{% block stylesheets %}
<style>
    .progress {
        background-color: #f0f0f0;
        border-radius: 10px;
        overflow: hidden;
    }
    
    .progress-bar {
        transition: width 1.5s ease;
    }
    
    .list-group-item {
        border-left: none;
        border-right: none;
        padding-left: 0;
        padding-right: 0;
    }
    
    .list-group-item:first-child {
        border-top: none;
    }
    
    .list-group-item:last-child {
        border-bottom: none;
    }
</style>
{% endblock %}
